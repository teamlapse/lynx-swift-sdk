platform :ios, '13.0'

# Disable input/output paths to avoid sandbox issues
install! 'cocoapods', :disable_input_output_paths => true

target 'LynxFrameworkBuilder' do
  use_frameworks! :linkage => :dynamic

  # Core Lynx Engine
  pod 'Lynx', '3.7.0', :subspecs => ['Framework']
  pod 'PrimJS', '3.7.0', :subspecs => ['quickjs', 'napi']

  # Lynx Services
  pod 'LynxService', '3.7.0', :subspecs => ['Log', 'Devtool']

  # Extended Elements
  pod 'XElement', '3.7.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      config.build_settings['SKIP_INSTALL'] = 'NO'
      # Disable treating deprecation warnings as errors (Lynx uses deprecated APIs)
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['OTHER_CFLAGS'] = '$(inherited) -Wno-error=deprecated-declarations -Wno-error=deprecated-implementations'

      # LynxServiceAPI 3.7.0 ships with a hardcoded CI path in HEADER_SEARCH_PATHS.
      # Override it so service_api/*.cc can find its own headers locally.
      if target.name == 'LynxServiceAPI'
        config.build_settings['HEADER_SEARCH_PATHS'] = '$(inherited) "${PODS_TARGET_SRCROOT}"'
      end
    end
  end

  # Also rewrite LynxServiceAPI xcconfig files directly — the podspec's
  # pod_target_xcconfig bakes the bad path in at generation time.
  Dir.glob("#{installer.sandbox.target_support_files_root}/LynxServiceAPI/*.xcconfig").each do |xcconfig|
    contents = File.read(xcconfig)
    patched = contents.gsub('"/Users/runner/work/lynx/lynx/lynx"', '"${PODS_TARGET_SRCROOT}"')
    File.write(xcconfig, patched) if patched != contents
  end
end
